# ================================================
# DiaPredict Environment Configuration
# Copy this file to .env and fill in the values
# ================================================

# ================================================
# FLASK CONFIGURATION
# ================================================

# Flask environment (development or production)
FLASK_ENV=development

# Flask debug mode (True or False)
FLASK_DEBUG=False

# Secret key for session encryption and CSRF tokens
# IMPORTANT: Generate a secure key for production
# Run: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-super-secret-key-change-this-in-production

# ================================================
# DATABASE CONFIGURATION
# ================================================

# Database URL (defaults to SQLite if not specified)
# Examples:
#   SQLite: sqlite:///diapredict.db (relative path)
#   SQLite: sqlite:////absolute/path/diapredict.db (absolute path)
#   MySQL: mysql+pymysql://user:password@localhost/diapredict
#   PostgreSQL: postgresql://user:password@localhost/diapredict
# DATABASE_URL=sqlite:///diapredict.db

# ================================================
# EMAIL CONFIGURATION (for notifications)
# ================================================

# SMTP server for sending emails
SMTP_SERVER=smtp.gmail.com

# SMTP port (typically 587 for TLS, 465 for SSL)
SMTP_PORT=587

# Sender email address (must be a valid email)
SENDER_EMAIL=your-email@gmail.com

# Email password or app-specific password
# For Gmail: Use an App Password (not your regular password)
# See: https://myaccount.google.com/apppasswords
SENDER_PASSWORD=your-email-app-password

# ================================================
# APPLICATION SETTINGS
# ================================================

# Application name
APP_NAME=DiaPredict

# Application version
APP_VERSION=1.0.0

# Session lifetime in hours
SESSION_LIFETIME_HOURS=24

# ================================================
# SECURITY SETTINGS
# ================================================

# Maximum login attempts before account lockout
MAX_LOGIN_ATTEMPTS=5

# Account lockout duration in minutes
LOCKOUT_DURATION_MINUTES=15

# Enable HTTPS/SSL (set to True in production)
# REQUIRE_HTTPS=False

# ================================================
# PRODUCTION CHECKLIST
# ================================================
# Before deploying to production:
#
# 1. Generate a new SECRET_KEY using:
#    python3 -c "import secrets; print(secrets.token_hex(32))"
#
# 2. Set FLASK_ENV=production
#
# 3. Configure a production database (not SQLite)
#
# 4. Set up SMTP email credentials
#
# 5. Use HTTPS in production (REQUIRE_HTTPS=True)
#
# 6. Review all security settings
#
# 7. Test email functionality
#
# 8. Back up your database
#
# ================================================
